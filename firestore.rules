rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "bwk.bruno@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidRegistrationStatus(status) {
      return status in ["pending", "approved", "cancelled"];
    }

    function isValidRegistrationAdminUpdate() {
      return request.resource.data.status is string &&
        isValidRegistrationStatus(request.resource.data.status) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "confirmedAt",
          "updatedAt",
          "manualConfirmation",
          "adminEmail",
          "lastPaymentStatus",
          "syncSource"
        ]);
    }

    function isValidEventData() {
      return request.resource.data.keys().hasOnly([
          "title",
          "description",
          "date",
          "targetAmount",
          "allowedAmounts",
          "active",
          "termsText",
          "updatedAt",
          "updatedBy"
        ]) &&
        request.resource.data.keys().hasAll(["title", "targetAmount", "allowedAmounts", "active", "termsText"]) &&
        request.resource.data.title is string &&
        request.resource.data.title.size() > 0 &&
        request.resource.data.title.size() <= 120 &&
        request.resource.data.targetAmount is number &&
        request.resource.data.targetAmount >= 0 &&
        request.resource.data.allowedAmounts is list &&
        request.resource.data.allowedAmounts.size() > 0 &&
        request.resource.data.allowedAmounts.size() <= 6 &&
        request.resource.data.active is bool &&
        request.resource.data.termsText is string &&
        request.resource.data.termsText.size() > 0 &&
        request.resource.data.termsText.size() <= 500 &&
        (!("description" in request.resource.data) || request.resource.data.description is string) &&
        (!("date" in request.resource.data) || request.resource.data.date is string) &&
        (!("updatedBy" in request.resource.data) || request.resource.data.updatedBy is string);
    }

    // Registrations
    match /registrations/{regId} {
      allow create: if false; // Registrations are created by the server with Admin SDK
      allow get: if true;    // Needed to check status on success page
      allow list: if isAdmin(); // Only admins see the full list
      
      allow update: if isAdmin() && isValidRegistrationAdminUpdate();
      allow delete: if false;
    }

    // Payment logs
    match /payment_logs/{logId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if false; // Server/Admin SDK only
    }

    // Events
    match /events/{eventId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidEventData();
      allow delete: if isAdmin();
    }
    
    // Admins collection
    match /admins/{adminId} {
      allow read, write: if false; // System only
    }
  }
}
