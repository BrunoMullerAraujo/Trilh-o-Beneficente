rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'bwk.bruno@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (
          exists(/databases/$(database)/documents/settings/allowed_admins) &&
          request.auth.token.email in get(/databases/$(database)/documents/settings/allowed_admins).data.emails
        )
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---

    function isValidRegistration(data) {
      return data.keys().hasAll(['name', 'email', 'phone', 'cpf', 'amount', 'status', 'paymentId', 'termsAccepted', 'createdAt', 'birthDate', 'motorcycle', 'cep', 'street', 'number', 'neighborhood', 'city', 'state', 'emergencyName', 'emergencyPhone']) &&
             data.keys().size() <= 42 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.phone is string && data.phone.size() <= 20 &&
             data.cpf is string && data.cpf.size() <= 15 &&
             data.birthDate is string &&
             data.motorcycle is string && data.motorcycle.size() <= 100 &&
             data.cep is string && data.cep.size() <= 10 &&
             data.street is string && data.street.size() <= 150 &&
             data.number is string && data.number.size() <= 20 &&
             data.neighborhood is string && data.neighborhood.size() <= 100 &&
             data.city is string && data.city.size() <= 100 &&
             data.state is string && data.state.size() <= 2 &&
             data.emergencyName is string && data.emergencyName.size() <= 100 &&
             data.emergencyPhone is string && data.emergencyPhone.size() <= 20 &&
             data.amount is number && data.amount > 0 &&
             data.status in ['pending', 'approved', 'cancelled'] &&
             data.paymentId is string && data.paymentId.size() <= 50 &&
             (!('orderId' in data) || (data.orderId is string && data.orderId.size() <= 50)) &&
             (!('guardianName' in data) || (data.guardianName is string && data.guardianName.size() <= 100)) &&
             (!('guardianCpf' in data) || (data.guardianCpf is string && data.guardianCpf.size() <= 15)) &&
             (!('complement' in data) || (data.complement is string && data.complement.size() <= 100)) &&
             (!('shirtSize' in data) || (data.shirtSize is string && data.shirtSize in ['P', 'M', 'G', 'GG', 'XGG', 'EX', ''])) &&
             (!('registrationNumber' in data) || (data.registrationNumber is string && data.registrationNumber.size() <= 10)) &&
             (!('pixCode' in data) || data.pixCode is string) &&
             (!('copyPaste' in data) || data.copyPaste is string) &&
             (!('nameEditedAt' in data) || data.nameEditedAt is string) &&
             (!('nameEditedBy' in data) || (data.nameEditedBy is string && data.nameEditedBy.size() <= 100)) &&
             (!('pixExpiresAt' in data) || data.pixExpiresAt is string) &&
             data.termsAccepted == true &&
             data.createdAt is string;
    }

    function isValidLog(data) {
      return data.keys().hasAll(['paymentId', 'timestamp']) &&
             data.paymentId is string &&
             data.timestamp is timestamp;
    }

    // --- Rules ---

    match /registrations/{registrationId} {
      // Create: Anyone can register
      allow create: if isValidRegistration(incoming()) && 
                       incoming().status == 'pending'; // Initial status must be pending
      
      // Get: necessário para a PaymentPage exibir status em tempo real via onSnapshot.
      // O ID do documento é gerado pelo Firestore e transmitido apenas via URL privada
      // do usuário — não é listável por anônimos (list só admins).
      allow get: if true;

      // List: Only Admins
      allow list: if isAdmin();

      // Update: Only Admin or automated system? 
      // server.ts uses Admin SDK which bypasses rules, but for client-side audit tools:
      allow update: if (
        isAdmin() && 
        isValidRegistration(incoming()) && (
          // Allow admin to update any field or specific actions
          incoming().diff(existing()).affectedKeys().hasAny(['status', 'confirmedAt', 'updatedAt', 'manualConfirmation', 'adminEmail', 'syncSource', 'name', 'nameEditedAt', 'nameEditedBy'])
        )
      );

      allow delete: if isAdmin();
    }

    match /payment_logs/{logId} {
      allow read, write: if isAdmin();
    }

    match /message_queue/{messageId} {
      allow read: if isAdmin();
      allow write: if false; // Escrita apenas pelo servidor (Admin SDK)
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console
    }

    match /settings/allowed_admins {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /settings/shirt_inventory {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/shirt_inventory_total {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /settings/event_config {
      allow read: if true;        // Lido pelo formulário público
      allow write: if isAdmin();  // Alterado somente pelo admin
    }

    match /settings/registration_counter {
      allow read: if true;
      // Escrita restrita: apenas incremento válido do contador de inscrição
      allow write: if incoming().keys().hasOnly(['lastNumber']) &&
                      incoming().lastNumber is int &&
                      incoming().lastNumber > 0;
    }

    match /settings/whatsapp_ban {
      allow read: if isAdmin();
      allow write: if false; // Escrito apenas pelo servidor (Admin SDK)
    }

    match /settings/whatsapp_session {
      allow read: if isAdmin();
      allow write: if false; // Escrito apenas pelo servidor (Admin SDK)
    }
  }
}
