{
  "entities": {
    "Event": {
      "title": "Evento",
      "description": "Configurações do evento beneficente",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "targetAmount": { "type": "number" }
      },
      "required": ["title", "price"]
    },
    "Registration": {
      "title": "Inscrição",
      "description": "Dados do participante e status do pagamento",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "cpf": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "cancelled"] },
        "paymentId": { "type": "string" },
        "pixCode": { "type": "string" },
        "qrCode": { "type": "string" },
        "amount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "status"]
    }
  },
  "firestore": {
    "events": {
      "schema": "Event",
      "description": "Coleção de eventos (geralmente apenas um no MVP)"
    },
    "registrations": {
      "schema": "Registration",
      "description": "Coleção de todas as inscrições realizadas"
    }
  }
}
