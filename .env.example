# GEMINI_API_KEY: Herdado do template AI Studio — não utilizado neste projeto.
# GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: URL completa onde o app está hospedado.
# Usado para links de retorno, webhook do Mercado Pago e endpoints de API.
# Exemplo Railway: https://trilhao-web-production.up.railway.app
APP_URL="MY_APP_URL"

# ── Mercado Pago ─────────────────────────────────────────────────────────────
# Obtenha em: Seu negócio > Integrações > Credenciais
# Use APP_USR-... (não TEST-...) para produção.
MERCADO_PAGO_ACCESS_TOKEN=""
VITE_MERCADO_PAGO_PUBLIC_KEY=""

# "true" somente com credenciais de teste do Mercado Pago
VITE_MERCADO_PAGO_TEST_BUYER="false"

# ── Configuração do Evento ────────────────────────────────────────────────────
# Preço da inscrição em BRL (padrão: 1.00)
EVENT_PRICE="1"
# E-mail do administrador principal (acesso admin sem entrada no Firestore)
ADMIN_EMAIL="bwk.bruno@gmail.com"
# Origens CORS adicionais além de APP_URL (separadas por vírgula)
# ALLOWED_ORIGINS="https://trilhao-web-production.up.railway.app"
# Secret HMAC-SHA256 para verificação do webhook do Mercado Pago
# Configure em: MP Panel > Seu negócio > Integrações > Webhooks
# WEBHOOK_SECRET="your-webhook-secret-here"

# ── Firebase Admin ────────────────────────────────────────────────────────────
# Prefira FIREBASE_SERVICE_ACCOUNT_KEY com o JSON completo da service account.
# Alternativamente, use FIREBASE_CLIENT_EMAIL + FIREBASE_PRIVATE_KEY.
FIREBASE_SERVICE_ACCOUNT_KEY=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# ── E-mail ────────────────────────────────────────────────────────────────────
# Brevo (preferido): https://app.brevo.com > SMTP & API > API Keys
BREVO_API_KEY=""
# Resend (fallback se BREVO_API_KEY ausente): https://resend.com
RESEND_API_KEY=""
# Remetente (use domínio verificado no Brevo/Resend)
EMAIL_FROM="Trilhão Beneficente <noreply@seudominio.com.br>"

# ── WhatsApp Meta Cloud API ───────────────────────────────────────────────────
# Modo seguro padrão: não envia mensagens reais.
# Para produção, configure as credenciais, teste primeiro com WHATSAPP_DRY_RUN="true",
# e só depois altere WHATSAPP_ENABLED="true" + WHATSAPP_DRY_RUN="false".
WHATSAPP_ENABLED="false"
WHATSAPP_DRY_RUN="true"

# Configuração para envio de notificações WhatsApp via API oficial.
# Consulte docs/WHATSAPP_META_CLOUD.md para o passo a passo completo.
#
# 1. Versão da Graph API da Meta (padrão: v20.0)
META_GRAPH_VERSION="v20.0"
#
# 2. Token de acesso permanente gerado no painel Meta for Developers
#    Obtenha em: Meta for Developers > seu app > WhatsApp > API Setup > Access Token
WHATSAPP_ACCESS_TOKEN=""
#
# 3. ID do número de telefone WhatsApp Business
#    Obtenha em: Meta for Developers > seu app > WhatsApp > API Setup > Phone Number ID
WHATSAPP_PHONE_NUMBER_ID=""
#
# 4. ID da conta WhatsApp Business
#    Obtenha em: Meta for Developers > seu app > WhatsApp > API Setup > Business Account ID
WHATSAPP_BUSINESS_ACCOUNT_ID=""
#
# 5. Token de verificação do webhook (string aleatória que você define)
#    Deve ser configurado também no painel Meta ao registrar o webhook
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""
#
# 6. App Secret do app Meta (para validação HMAC do webhook)
#    Obtenha em: Meta for Developers > seu app > Configurações > Básico > App secret
META_APP_SECRET=""
