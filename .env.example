# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
# On Vercel, use your production URL, for example:
# APP_URL="https://trilh-o-beneficente.vercel.app"
# Used for self-referential links, webhook callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Mercado Pago Configuration
# Get your access token and public key from Mercado Pago Panel
MERCADO_PAGO_ACCESS_TOKEN=""
VITE_MERCADO_PAGO_PUBLIC_KEY=""

# Use "true" only with Mercado Pago test credentials (TEST-...)
VITE_MERCADO_PAGO_TEST_BUYER="false"

# Event configuration
# Price of the inscription in BRL (default: 1.00)
EVENT_PRICE="1"
# Admin email address (grants admin access without Firestore admins collection entry)
ADMIN_EMAIL="bwk.bruno@gmail.com"
# CORS: comma-separated list of allowed origins (besides APP_URL which is always included)
# ALLOWED_ORIGINS="https://trilhao-web-production.up.railway.app"
# Mercado Pago webhook secret for HMAC-SHA256 signature verification
# Configure in MP panel: Seu negócio > Integrações > Webhooks
# WEBHOOK_SECRET="your-webhook-secret-here"

# Firebase Admin credentials for serverless webhook/payment verification.
# Prefer FIREBASE_SERVICE_ACCOUNT_KEY with the full service account JSON.
# Alternatively set FIREBASE_CLIENT_EMAIL and FIREBASE_PRIVATE_KEY.
FIREBASE_SERVICE_ACCOUNT_KEY=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# E-mail de confirmação via Resend (https://resend.com)
# Crie uma conta, verifique o domínio e gere a API key
RESEND_API_KEY=""
# Remetente do e-mail (deve usar domínio verificado no Resend)
EMAIL_FROM="Trilhão Beneficente <noreply@seudominio.com.br>"
