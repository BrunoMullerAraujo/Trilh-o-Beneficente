# URL pública do app. Em produção deve ser a URL do Cloud Run/hosting.
# Usada para montar o endpoint de webhook enviado ao Mercado Pago.
APP_URL="https://seu-app.exemplo.com"

# Credenciais do Mercado Pago.
# Configure o access token no painel de segredos do ambiente.
MERCADO_PAGO_ACCESS_TOKEN=""

# Segredo do webhook usado para validar o cabeçalho x-signature.
MERCADO_PAGO_WEBHOOK_SECRET=""
